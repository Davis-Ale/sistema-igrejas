generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  PASTOR
  LEADER
  VOLUNTEER
  MEMBER
  VISITOR
}

enum VolunteerStatus {
  IN_FORMATION
  ELIGIBLE
  ACTIVE
  SUSPENDED
}

enum VisitorStatus {
  NEW
  CONTACTED
  INTEGRATED
  ARCHIVED
}

enum UserAccountStatus {
  ACTIVE
  DISABLED
}

enum ChurchStatus {
  TRIAL
  ACTIVE
  BLOCKED
  CANCELLED
}

enum TrialStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  BLOCKED
}

enum RegStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
}

enum TxType {
  TITHE
  OFFERING
  EVENT
  EXPENSE
  OTHER
}

enum TxDirection {
  IN
  OUT
}

enum PayMethod {
  PIX
  CARD
  CASH
  BOLETO
}

model Church {
  id        String   @id @default(cuid())
  churchId  String   @unique @default(cuid())
  name      String
  slug      String   @unique
  plan      String
  status                ChurchStatus @default(TRIAL)
  cnpj      String?
  locale    String   @default("pt-BR")
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  blockedAt             DateTime?
  blockReason           String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campuses      Campus[]
  people        Person[]
  trails        Trail[]
  trailStages   TrailStage[]
  trailProgress TrailProgress[]
  celulas       Celula[]
  memberships   Membership[]
  volunteerLogs VolunteerLog[]
  events        Event[]
  registrations Registration[]
  transactions  Transaction[]
  userAccounts UserAccount[]
  trialSignups TrialSignup[]
  visitors      Visitor[]

  @@index([churchId])
  @@index([cnpj])
}

model Campus {
  id             String   @id @default(cuid())
  churchId       String
  name           String
  cnpj           String?
  asaasAccountId String?
  address        String?
  isHeadquarters Boolean  @default(false)
  pastorId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  pastor Person? @relation("CampusPastor", fields: [pastorId], references: [id], onDelete: SetNull)

  people       Person[]
  celulas      Celula[]
  events       Event[]
  transactions Transaction[]
  visitors     Visitor[]

  @@index([churchId])
  @@index([churchId, cnpj])
  @@index([churchId, pastorId])
  @@index([churchId, isHeadquarters])
}

model Visitor {
  id           String        @id @default(cuid())
  churchId     String
  campusId     String?
  name         String
  phone        String
  email        String?
  status       VisitorStatus @default(NEW)
  firstVisitAt DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  registrations Registration[]

  @@index([churchId])
  @@index([churchId, campusId])
  @@index([churchId, email])
  @@index([churchId, phone])
  @@index([churchId, status])
  @@index([churchId, firstVisitAt])
}

model Person {
  id              String          @id @default(cuid())
  churchId        String
  campusId        String?
  name            String
  phone           String
  email           String?
  role            Role            @default(MEMBER)
  volunteerStatus VolunteerStatus @default(IN_FORMATION)
  trailStageId    String?
  celulaId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  trailStage TrailStage? @relation("PersonCurrentTrailStage", fields: [trailStageId], references: [id], onDelete: SetNull)
  celula     Celula?     @relation("PersonCelula", fields: [celulaId], references: [id], onDelete: SetNull)

  ledCampuses        Campus[]        @relation("CampusPastor")
  ledCelulas         Celula[]        @relation("CelulaLeader")
  trailProgress      TrailProgress[] @relation("PersonTrailProgress")
  approvedProgress   TrailProgress[] @relation("TrailProgressApprover")
  memberships        Membership[]    @relation("PersonMembership")
  approvedMembership Membership[]    @relation("MembershipApprover")
  volunteerLogs      VolunteerLog[]  @relation("VolunteerLogPerson")
  changedLogs        VolunteerLog[]  @relation("VolunteerLogChangedBy")
  registrations      Registration[]
  transactions       Transaction[]
  userAccount       UserAccount?

  @@index([churchId])
  @@index([churchId, campusId])
  @@index([churchId, email])
  @@index([churchId, phone])
  @@index([churchId, role])
  @@index([churchId, volunteerStatus])
  @@index([churchId, celulaId])
  @@index([churchId, trailStageId])
}

model Trail {
  id              String   @id @default(cuid())
  churchId        String
  name            String
  isVolunteerGate Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  stages TrailStage[]

  @@index([churchId])
  @@index([churchId, isVolunteerGate])
}

model TrailStage {
  id              String   @id @default(cuid())
  churchId        String
  trailId         String
  label           String
  order           Int
  requiresEventId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  trail  Trail  @relation(fields: [trailId], references: [id], onDelete: Cascade)

  requiresEvent Event? @relation("TrailStageRequiredEvent", fields: [requiresEventId], references: [id], onDelete: SetNull)

  currentPeople Person[]        @relation("PersonCurrentTrailStage")
  progress      TrailProgress[]
  events        Event[]         @relation("EventTrailStage")

  @@index([churchId])
  @@index([churchId, trailId])
  @@index([churchId, requiresEventId])
  @@unique([trailId, order])
}

model TrailProgress {
  id          String    @id @default(cuid())
  churchId    String
  personId    String
  stageId     String
  completedAt DateTime?
  approvedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  person   Person     @relation("PersonTrailProgress", fields: [personId], references: [id], onDelete: Cascade)
  stage    TrailStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  approver Person?    @relation("TrailProgressApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([churchId])
  @@index([churchId, personId])
  @@index([churchId, stageId])
  @@index([churchId, approvedBy])
  @@unique([personId, stageId])
}

model Celula {
  id        String   @id @default(cuid())
  churchId  String
  campusId  String?
  leaderId  String
  name      String
  region    String
  meetDay   String
  meetTime  String   @default("")
  profile   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)
  leader Person  @relation("CelulaLeader", fields: [leaderId], references: [id], onDelete: Restrict)

  people      Person[]     @relation("PersonCelula")
  memberships Membership[]

  @@index([churchId])
  @@index([churchId, campusId])
  @@index([churchId, leaderId])
  @@index([churchId, region])
}

model Membership {
  id           String    @id @default(cuid())
  churchId     String
  personId     String
  groupId      String
  canVolunteer Boolean   @default(false)
  approvedBy   String?
  removedAt    DateTime?
  removalNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  person   Person  @relation("PersonMembership", fields: [personId], references: [id], onDelete: Cascade)
  celula   Celula  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  approver Person? @relation("MembershipApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([churchId])
  @@index([churchId, personId])
  @@index([churchId, groupId])
  @@index([churchId, approvedBy])
  @@index([churchId, canVolunteer])
}

model VolunteerLog {
  id        String          @id @default(cuid())
  churchId  String
  personId  String
  status    VolunteerStatus
  changedBy String
  reason    String?
  at        DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  person  Person @relation("VolunteerLogPerson", fields: [personId], references: [id], onDelete: Cascade)
  changer Person @relation("VolunteerLogChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([churchId])
  @@index([churchId, personId])
  @@index([churchId, changedBy])
  @@index([churchId, status])
  @@index([churchId, at])
}

model Event {
  id                        String   @id @default(cuid())
  churchId                  String
  campusId                  String?
  title                     String
  slug                      String
  date                      DateTime
  capacity                  Int
  price                     Decimal  @default(0) @db.Decimal(12, 2)
  isPublic                  Boolean  @default(false)
  isPaid                    Boolean  @default(false)
  publicRegistrationEnabled Boolean  @default(false)
  waitlistEnabled           Boolean  @default(true)
  trailStageId              String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  trailStage TrailStage? @relation("EventTrailStage", fields: [trailStageId], references: [id], onDelete: SetNull)

  requiredByStages TrailStage[]   @relation("TrailStageRequiredEvent")
  registrations    Registration[]
  transactions     Transaction[]

  @@index([churchId])
  @@index([churchId, campusId])
  @@index([churchId, slug])
  @@index([churchId, date])
  @@index([churchId, isPublic])
  @@index([churchId, isPaid])
  @@index([churchId, publicRegistrationEnabled])
  @@index([churchId, trailStageId])
  @@unique([churchId, slug])
}

model Registration {
  id                   String    @id @default(cuid())
  churchId             String
  eventId              String
  personId             String?
  visitorId            String?
  status               RegStatus @default(PENDING)
  paymentStatus        String    @default("NOT_REQUIRED")
  paymentId            String?
  checkInToken         String    @unique @default(cuid())
  checkedInAt          DateTime?
  confirmedAt          DateTime?
  waitlistedAt         DateTime?
  registrationSource   String    @default("ADMIN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person  Person?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  visitor Visitor? @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([churchId, eventId])
  @@index([churchId, personId])
  @@index([churchId, visitorId])
  @@index([churchId, status])
  @@index([churchId, paymentStatus])
  @@index([churchId, paymentId])
  @@index([churchId, checkInToken])
  @@index([churchId, registrationSource])
  @@unique([eventId, personId])
  @@unique([eventId, visitorId])
}

model Transaction {
  id         String      @id @default(cuid())
  churchId   String
  campusId   String?
  cnpj       String?
  personId   String?
  eventId    String?
  type       TxType
  direction  TxDirection
  amount     Decimal     @db.Decimal(12, 2)
  method     PayMethod
  costCenter String
  asaasId    String?
  nfseId     String?
  at         DateTime    @default(now())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
  event  Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([churchId])
  @@index([churchId, campusId])
  @@index([churchId, cnpj])
  @@index([churchId, personId])
  @@index([churchId, eventId])
  @@index([churchId, type])
  @@index([churchId, direction])
  @@index([churchId, method])
  @@index([churchId, costCenter])
  @@index([churchId, asaasId])
  @@index([churchId, nfseId])
  @@index([churchId, at])
}

model UserAccount {
  id           String            @id @default(cuid())
  churchId     String
  personId     String?           @unique
  email        String            @unique
  passwordHash String
  role         Role
  status       UserAccountStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  church Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([churchId])
  @@index([churchId, role])
  @@index([churchId, status])
  @@index([email])
}

model TrialSignup {
  id          String      @id @default(cuid())
  email       String      @unique
  churchId    String?
  status      TrialStatus @default(ACTIVE)
  startedAt   DateTime    @default(now())
  endsAt      DateTime?
  convertedAt DateTime?
  blockedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  church Church? @relation(fields: [churchId], references: [id], onDelete: SetNull)

  @@index([churchId])
  @@index([email])
  @@index([status])
}
