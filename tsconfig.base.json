{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@sistema-igrejas/auth": ["packages/auth/src/index.ts"],
      "@sistema-igrejas/database": ["packages/database/src/index.ts"],
      "@sistema-igrejas/domain": ["packages/domain/src/index.ts"],
      "@sistema-igrejas/members": ["packages/members/src/index.ts"],
      "@sistema-igrejas/trail": ["packages/trail/src/index.ts"],
      "@sistema-igrejas/volunteers": ["packages/volunteers/src/index.ts"],
      "@sistema-igrejas/events": ["packages/events/src/index.ts"],
      "@sistema-igrejas/financial": ["packages/financial/src/index.ts"],
      "@sistema-igrejas/notifications": ["packages/notifications/src/index.ts"]
    }
  }
}
